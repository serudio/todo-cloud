{
  "name": "todo-cloud",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "tsx watch api/src/server.ts",
    "build": "pnpm build:web && pnpm build:api",
    "build:web": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "build:api": "tsc -b api",
    "db:migrate": "tsx scripts/migrate.ts",
    "preview": "vite preview",
    "start:api": "node api/dist/server.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hono/node-server": "^2.0.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.4",
    "@supabase/supabase-js": "^2.105.1",
    "dayjs": "^1.11.20",
    "hono": "^4.12.15",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
