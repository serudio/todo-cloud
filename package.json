{
  "name": "todo-cloud",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "tsx watch api/src/server.ts",
    "build": "pnpm build:web && pnpm build:api",
    "build:web": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "build:api": "tsc -b api",
    "db:migrate": "tsx scripts/migrate.ts",
    "preview": "vite preview",
    "start:api": "node api/dist/server.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.15",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
